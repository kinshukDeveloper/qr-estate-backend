{
  "name": "qr-estate-backend",
  "version": "1.0.0",
  "description": "QR Real Estate Platform — Express API",
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "test": "jest --coverage --runInBand",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .js",
    "db:migrate": "node-pg-migrate -m migrations up",
    "db:rollback": "node-pg-migrate -m migrations down",
    "db:create": "node-pg-migrate -m migrations create",
    "db:seed": "node seeds/seed.js",
    "db:seed-v2": "node seeds/seed-v2.js",
    "db:reset": "npm run db:rollback && npm run db:migrate && npm run db:seed",
    "db:seed:leads": "node seeds/seed-leads.js"
  },
  "dependencies": {
    "@upstash/redis": "^1.37.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.0.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "joi": "^17.12.3",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^3.3.7",
    "node-cron": "^3.0.3",
    "node-pg-migrate": "^6.2.2",
    "pg": "^8.11.5",
    "puppeteer": "^22.0.0",
    "qrcode": "^1.5.3",
    "razorpay": "^2.9.2",
    "redis": "^5.11.0",
    "serverless-http": "^4.0.0",
    "sharp": "^0.33.3",
    "twilio": "^5.0.4",
    "uuid": "^9.0.1",
    "winston": "^3.13.0",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js"
    ]
  }
}
