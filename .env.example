# ─────────────────────────────────────────────
#  QR ESTATE — BACKEND ENVIRONMENT VARIABLES
#  Copy this file to .env and fill in values
#  NEVER commit .env to git
# ─────────────────────────────────────────────

# ── SERVER ──────────────────────────────────
NODE_ENV=development
PORT=5000
API_VERSION=v1

# ── DATABASE (PostgreSQL) ────────────────────
# Local dev: install PostgreSQL and create a DB named qr_estate
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/qr_estate
DB_HOST=localhost
DB_PORT=5432
DB_NAME=qr_estate
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_SSL=false

# ── REDIS ────────────────────────────────────
# Local dev: install Redis or use Docker: docker run -p 6379:6379 redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# ── JWT ──────────────────────────────────────
# Generate strong secrets: openssl rand -base64 64
JWT_ACCESS_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_64
JWT_REFRESH_SECRET=CHANGE_ME_different_secret_generate_with_openssl
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── CLOUDINARY (Media Storage) ───────────────
# Get from: https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── TWILIO (WhatsApp + SMS) ──────────────────
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_SMS_FROM=+1234567890

# ── SENDGRID (Email) ─────────────────────────
# Get from: https://app.sendgrid.com → API Keys
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@qrestate.in
EMAIL_FROM_NAME=QR Estate

# ── RAZORPAY (Payments) ──────────────────────
# Get from: https://dashboard.razorpay.com → API Keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ── FRONTEND URL (for CORS + links in emails) ─
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── APP ──────────────────────────────────────
APP_NAME=QR Estate
APP_URL=http://localhost:5000
SHORT_URL_BASE=http://localhost:5000/q

# ── RATE LIMITING ────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ── BCRYPT ───────────────────────────────────
BCRYPT_SALT_ROUNDS=12
